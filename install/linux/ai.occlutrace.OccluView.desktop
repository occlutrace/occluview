[Desktop Entry]
Type=Application
Name=OccluView
GenericName=3D Mesh Viewer
Comment=Open dental scans and common 3D mesh files
Exec=occluview %F
Icon=occluview
Terminal=false
Categories=Graphics;3DGraphics;Viewer;
# The app forwards the launch token to its existing X11/Wayland surface after
# the window is created, so file-manager launches can activate the viewer.
StartupNotify=true
StartupWMClass=ai.occlutrace.OccluView
MimeType=model/stl;model/obj;model/gltf-binary;application/x-ply;application/x-occluview-hps;
