              <RegistryValue Type="string" Value="" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\.hps\OpenWithList\occluview.exe">
              <RegistryValue Type="string" Value="" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\RegisteredApplications">
              <RegistryValue Name="OccluView" Type="string" Value="Software\OccluTrace\OccluView\Capabilities" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\OccluTrace\OccluView\Capabilities">
              <RegistryValue Name="ApplicationName" Type="string" Value="$(var.ProductName)" />
              <RegistryValue Name="ApplicationDescription" Type="string" Value="Fast 3D mesh viewer for dental scans and open mesh files." />
              <RegistryValue Name="ApplicationIcon" Type="string" Value="[INSTALLFOLDER]occluview.exe,0" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\OccluTrace\OccluView\Capabilities\FileAssociations">
              <RegistryValue Name=".stl" Type="string" Value="MeshFile.STL" />
              <RegistryValue Name=".ply" Type="string" Value="MeshFile.PLY" />
              <RegistryValue Name=".obj" Type="string" Value="MeshFile.OBJ" />
              <RegistryValue Name=".glb" Type="string" Value="MeshFile.GLB" />
              <RegistryValue Name=".dcm" Type="string" Value="MeshFile.HPS" />
              <RegistryValue Name=".hps" Type="string" Value="MeshFile.HPS" />
            </RegistryKey>
          </Component>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="OccluView">
          <Component Id="cmpStartMenuShortcut" Guid="{C1CB7607-75E0-4112-9ECC-607B7561A73B}" Win64="yes">
            <Shortcut
              Id="shcOccluView"
              Name="$(var.ProductName)"
              Description="Open the OccluView 3D scan viewer"
              Target="[#filOccluViewExe]"
              WorkingDirectory="INSTALLFOLDER"
              Icon="OccluViewIcon.ico">
              <ShortcutProperty Key="System.AppUserModel.ID" Value="OccluTrace.OccluView" />
            </Shortcut>
            <RemoveFolder Id="rmProgramMenuDir" On="uninstall" />
            <RegistryValue
              Root="HKCU"
              Key="Software\OccluTrace\OccluView"
              Name="StartMenuShortcut"
              Type="integer"
              Value="1"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="featOccluView" Title="$(var.ProductName)" Level="1">
      <ComponentRef Id="cmpOccluViewExe" />
      <ComponentRef Id="cmpOccluViewShellDll" />
      <ComponentRef Id="cmpFormatIcon3d" />
      <ComponentRef Id="cmpShellRegistration" />
      <ComponentRef Id="cmpStartMenuShortcut" />
    </Feature>
  </Product>
</Wix>
