<?xml version="1.0" encoding="UTF-8"?>
<?define ProductName = "OccluView 3D Viewer" ?>
<?define Manufacturer = "Dental Cloud Technologies" ?>
<?define UpgradeCode = "{9DA29242-E8A8-4A71-BEEB-04EEAB667157}" ?>
<?define ThumbnailProviderCategory = "{E357FCCD-A995-4576-B01F-234630154E96}" ?>
<?define PreviewHandlerCategory = "{8895B1C6-B41F-4C1C-A562-0D564250836F}" ?>
<?define ShellClsid = "{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}" ?>
<?define PreviewClsid = "{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}" ?>
<?define PrevhostAppId = "{6D2B5079-2F0B-48DD-AB7F-97CEC514D30B}" ?>
<?ifndef ProductVersion?>
<?define ProductVersion = "1.0.4" ?>
<?endif?>
<?ifndef BuildDir?>
<?define BuildDir = "target\x86_64-pc-windows-msvc\release" ?>
<?endif?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="$(var.ProductName)"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="$(var.Manufacturer)"
    UpgradeCode="$(var.UpgradeCode)">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <!--
      ProductVersion is passed in from build-msi.ps1 (-dProductVersion) and
      defaults to the value defined at the top of this file. MSI ProductVersion
      is X.Y.Z only; the Product/@Id is "*" so every build gets a fresh
      ProductCode while the fixed UpgradeCode below drives MajorUpgrade.
    -->
    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of OccluView is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <!--
      Product icon shown in Add/Remove Programs and on shortcuts. Sourced from
      the packaged multi-resolution .ico (16/24/32/48/64/128/256) so it stays
      crisp at every DPI. Id keeps the .ico extension per WiX icon convention.
    -->
    <Icon Id="OccluViewIcon.ico" SourceFile="$(sys.SOURCEFILEDIR)..\crates\occluview-app\assets\windows\occluview.ico" />
    <Property Id="ARPPRODUCTICON" Value="OccluViewIcon.ico" />
    <Property Id="ARPCOMMENTS" Value="Fast 3D mesh viewer for dental scans and open mesh files." />
    <Property Id="ARPCONTACT" Value="$(var.Manufacturer)" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/occlutrace/OccluView" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/occlutrace/OccluView/releases" />
    <Property Id="ARPHELPLINK" Value="https://github.com/occlutrace/OccluView/issues" />
    <!-- Single-feature product: no user-selectable features and repair is a
         no-op, so hide the Modify and Repair buttons in Add/Remove Programs. -->
    <Property Id="ARPNOREPAIR" Value="1" />
    <!-- Branded WixUI_InstallDir flow: Welcome -> License -> InstallDir ->
         Verify -> Progress -> Exit. Banner/dialog artwork is generated by
         install/assets/gen-installer-art.py. -->
    <UIRef Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)license.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="$(sys.SOURCEFILEDIR)assets\WixUIBannerBmp.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(sys.SOURCEFILEDIR)assets\WixUIDialogBmp.bmp" />
    <CustomAction
      Id="RefreshShellAssociationsInstall"
      FileKey="filOccluViewExe"
      ExeCommand="--shell-refresh"
      Execute="deferred"
      Return="check"
      Impersonate="no" />
    <CustomAction
      Id="RefreshShellAssociationsUninstall"
      FileKey="filOccluViewExe"
      ExeCommand="--shell-refresh"
      Execute="deferred"
      Return="check"
      Impersonate="no" />
    <InstallExecuteSequence>
      <Custom Action="RefreshShellAssociationsInstall" After="WriteRegistryValues">NOT REMOVE</Custom>
      <Custom Action="RefreshShellAssociationsUninstall" After="RemoveRegistryValues">REMOVE="ALL"</Custom>
    </InstallExecuteSequence>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="OccluView">
          <Component Id="cmpOccluViewExe" Guid="{EB8EF0C2-A3F3-4A1E-AEC2-76346B975D89}" Win64="yes">
            <File Id="filOccluViewExe" Source="$(var.BuildDir)\occluview.exe" KeyPath="yes" />
          </Component>
          <Component Id="cmpOccluViewShellDll" Guid="{5F834B2B-71E8-444D-82F7-4F683AAF70DB}" Win64="yes">
            <File
              Id="filOccluViewShellDll"
              Source="$(var.BuildDir)\occluview_shell.dll"
              KeyPath="yes" />
          </Component>
          <Component Id="cmpFormatIcon3d" Guid="{4B39EB44-2AA6-4908-9A69-94361855695C}" Win64="yes">
            <File
              Id="filFormatIcon3d"
              Source="$(sys.SOURCEFILEDIR)assets\file-icons\occluview-3d.ico"
              KeyPath="yes" />
          </Component>
          <Component Id="cmpShellRegistration" Guid="{2B247A1D-C712-4B12-A4CE-E0AAD092966D}" Win64="yes">
            <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\$(var.ShellClsid)">
              <RegistryValue Type="string" Value="OccluView Thumbnail Provider" KeyPath="yes" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\$(var.ShellClsid)\InprocServer32">
              <RegistryValue Type="string" Value="[INSTALLFOLDER]occluview_shell.dll" />
              <RegistryValue Name="ThreadingModel" Type="string" Value="Apartment" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\$(var.PreviewClsid)">
              <RegistryValue Type="string" Value="OccluView Preview Handler" />
              <RegistryValue Name="AppID" Type="string" Value="$(var.PrevhostAppId)" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\$(var.PreviewClsid)\InprocServer32">
              <RegistryValue Type="string" Value="[INSTALLFOLDER]occluview_shell.dll" />
              <RegistryValue Name="ThreadingModel" Type="string" Value="Apartment" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Shell Extensions\Approved">
              <RegistryValue Name="$(var.ShellClsid)" Type="string" Value="OccluView Thumbnail Provider" />
              <RegistryValue Name="$(var.PreviewClsid)" Type="string" Value="OccluView Preview Handler" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\PreviewHandlers">
              <RegistryValue Name="$(var.PreviewClsid)" Type="string" Value="OccluView Preview Handler" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\MeshFile.STL">
              <RegistryValue Type="string" Value="STL File" />
              <RegistryValue Name="ThumbnailCutoff" Type="integer" Value="1" />
              <RegistryValue Name="TypeOverlay" Type="string" Value="" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\MeshFile.STL\ShellEx\$(var.ThumbnailProviderCategory)">
              <RegistryValue Type="string" Value="$(var.ShellClsid)" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\MeshFile.STL\ShellEx\$(var.PreviewHandlerCategory)">
              <RegistryValue Type="string" Value="$(var.PreviewClsid)" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\MeshFile.STL\DefaultIcon">
              <RegistryValue Type="string" Value="[INSTALLFOLDER]occluview-3d.ico" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="Software\Classes\MeshFile.STL\shell\open\command">
              <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]occluview.exe&quot; &quot;%1&quot;" />
            </RegistryKey>
