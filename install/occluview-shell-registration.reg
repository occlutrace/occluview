; --- Windows Default Apps discovery (does not set the default app) ---

[HKEY_LOCAL_MACHINE\Software\RegisteredApplications]
"OccluView"="Software\\OccluTrace\\OccluView\\Capabilities"

[HKEY_LOCAL_MACHINE\Software\OccluTrace\OccluView\Capabilities]
"ApplicationName"="OccluView 3D Viewer"
"ApplicationDescription"="Fast 3D mesh viewer for dental scans and open mesh files."
"ApplicationIcon"="<APP_EXE_PATH>,0"

[HKEY_LOCAL_MACHINE\Software\OccluTrace\OccluView\Capabilities\FileAssociations]
".stl"="MeshFile.STL"
".ply"="MeshFile.PLY"
".obj"="MeshFile.OBJ"
".glb"="MeshFile.GLB"
".dcm"="MeshFile.HPS"
".hps"="MeshFile.HPS"
