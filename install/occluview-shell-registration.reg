Windows Registry Editor Version 5.00

; OccluView shell extension — manual registration script.
;
; Prefer `regsvr32 occluview_shell.dll` (runs DllRegisterServer, which fills in
; the absolute DLL path). This .reg file is a fallback for environments where
; regsvr32 is blocked by policy; replace <DLL_PATH> with the absolute path to
; occluview_shell.dll before importing.
;
; Layout:
;   HKCR\CLSID\{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}\InprocServer32
;       (default) = <DLL_PATH>
;       ThreadingModel = Apartment
;   HKCR\CLSID\{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}\InprocServer32
;       (default) = <DLL_PATH>
;       ThreadingModel = Apartment
;   HKLM\Software\Microsoft\Windows\CurrentVersion\Shell Extensions\Approved
;       {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045} = "OccluView Thumbnail Provider"
;       {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046} = "OccluView Preview Handler"
;   HKLM\Software\Microsoft\Windows\CurrentVersion\PreviewHandlers
;       {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046} = "OccluView Preview Handler"
;   HKCR\<ext>\ShellEx\{E357FCCD-A995-4576-B01F-234630154E96}
;       (default) = {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}
;   HKCR\<ext>\ShellEx\{8895B1C6-B41F-4C1C-A562-0D564250836F}
;       (default) = {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}
;   HKCR\SystemFileAssociations\<ext>\ShellEx\{E357FCCD-A995-4576-B01F-234630154E96}
;       (default) = {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}
;   HKCR\SystemFileAssociations\<ext>\ShellEx\{8895B1C6-B41F-4C1C-A562-0D564250836F}
;       (default) = {9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}
;
;   HKCR\MeshFile.<EXT>                (per-format ProgID)
;       (default) = "<EXT> File"
;       DefaultIcon = "<APP_DIR>\occluview-3d.ico"
;       shell\open\command = "<APP_EXE_PATH>" "%1"
;       ThumbnailCutoff = 1 (allow thumbnails down to 16px)
;       TypeOverlay = "" (no app-brand overlay on the rendered thumbnail)
;   HKCR\Applications\occluview.exe          (Open With / Default Apps discovery)
;       shell\open\command = "<APP_EXE_PATH>" "%1"
;       SupportedTypes = .stl/.ply/.obj/.glb/.dcm/.hps
;   HKCR\<ext>
;       (default) = MeshFile.<EXT> (fallback only; user defaults can override)
;       ThumbnailCutoff = 1
;       TypeOverlay = ""
;       DefaultIcon = "<APP_DIR>\occluview-3d.ico"
;   HKCR\<ext>\OpenWithProgids
;       MeshFile.<EXT> = ""
;   HKCR\<ext>\OpenWithList\occluview.exe
;
; Replace <DLL_PATH> with the absolute path to occluview_shell.dll and
; <APP_EXE_PATH> with the absolute path to occluview.exe before importing.
; Replace <APP_DIR> with the directory containing occluview.exe and the
; occluview-*.ico format icons.
;
; The {E357FCCD-...} CLSID is the shell's well-known IThumbnailProvider
; category; {8895B1C6-...} is the shell's preview-handler category.

[HKEY_CLASSES_ROOT\CLSID\{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}]
@="OccluView Thumbnail Provider"

[HKEY_CLASSES_ROOT\CLSID\{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}\InprocServer32]
@="<DLL_PATH>"
"ThreadingModel"="Apartment"

[HKEY_CLASSES_ROOT\CLSID\{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}]
@="OccluView Preview Handler"
"AppID"="{6D2B5079-2F0B-48DD-AB7F-97CEC514D30B}"

[HKEY_CLASSES_ROOT\CLSID\{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}\InprocServer32]
@="<DLL_PATH>"
"ThreadingModel"="Apartment"

[HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Shell Extensions\Approved]
"{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}"="OccluView Thumbnail Provider"
"{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}"="OccluView Preview Handler"

[HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\PreviewHandlers]
"{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}"="OccluView Preview Handler"

[HKEY_CLASSES_ROOT\.stl]
@="MeshFile.STL"
"ThumbnailCutoff"=dword:00000001
"TypeOverlay"=""

[HKEY_CLASSES_ROOT\.stl\DefaultIcon]
@="<APP_DIR>\\occluview-3d.ico"

[HKEY_CLASSES_ROOT\.stl\ShellEx\{E357FCCD-A995-4576-B01F-234630154E96}]
@="{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}"

[HKEY_CLASSES_ROOT\.stl\ShellEx\{8895B1C6-B41F-4C1C-A562-0D564250836F}]
@="{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}"

[HKEY_CLASSES_ROOT\SystemFileAssociations\.stl\ShellEx\{E357FCCD-A995-4576-B01F-234630154E96}]
@="{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3045}"

[HKEY_CLASSES_ROOT\SystemFileAssociations\.stl\ShellEx\{8895B1C6-B41F-4C1C-A562-0D564250836F}]
@="{9F3A1B2C-4D5E-4F60-8A7B-9C0D1E2F3046}"

